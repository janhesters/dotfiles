# Run omarchy-restart-xcompose to apply changes

# Include fast emoji access
include "%H/.local/share/omarchy/default/xcompose"

# Identification
<Multi_key> <space> <n> : "janhesters"
<Multi_key> <space> <e> : "jan@earlynode.com"

# German umlauts (Compose + double-tap letter, faster than Compose + " + letter)
<Multi_key> <u> <u> : "ü"
<Multi_key> <o> <o> : "ö"
<Multi_key> <a> <a> : "ä"
<Multi_key> <U> <U> : "Ü"
<Multi_key> <O> <O> : "Ö"
<Multi_key> <A> <A> : "Ä"

# Bullet point shortcut (Compose + . + b, easier to remember than default Compose + . + =)
<Multi_key> <period> <b> : "•"
